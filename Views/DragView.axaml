<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PictureView.ViewModels"
    x:Class="PictureView.Views.DragView"
    x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="Rectangle#DropZoneBorder">
            <Setter Property="Stroke" Value="#d9d9d9" />
        </Style>

        <Style Selector="Rectangle#DropZoneBorder.dragover">
            <Setter Property="Stroke" Value="#0064fa" />
        </Style>
    </UserControl.Styles>

    <Grid
        Background="Transparent"
        Cursor="Hand"
        Margin="40"
        PointerPressed="OnDropZonePointerPressed">
        <Rectangle
            x:Name="DropZoneBorder"
            StrokeThickness="2"
            StrokeDashArray="4,4"
            RadiusX="8"
            RadiusY="8"
            Fill="Transparent">
            <Rectangle.Transitions>
                <Transitions>
                    <!-- 针对边框颜色的过渡 -->
                    <BrushTransition Property="Stroke" Duration="0:0:0.3" />
                </Transitions>
            </Rectangle.Transitions>
        </Rectangle>

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="16">
            <!-- 图标 -->
            <TextBlock
                Text="📁"
                FontSize="64"
                HorizontalAlignment="Center" />
            <!-- 文字 -->
            <TextBlock
                Text="点击选择 或 将图片文件夹拖拽到此处"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="#595959" />
            <TextBlock
                Text="支持添加多个文件夹"
                FontSize="14"
                Foreground="#8c8c8c"
                HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>